{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://rideai-backend.onrender.com",
        "EXPO_PUBLIC_SUPABASE_URL": "https://CHANGE-ME.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "CHANGE-ME"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://rideai-backend.onrender.com",
        "EXPO_PUBLIC_SUPABASE_URL": "https://CHANGE-ME.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "CHANGE-ME"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "CHANGE-ME@example.com",
        "ascAppId": "CHANGE-ME",
        "appleTeamId": "CHANGE-ME"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
