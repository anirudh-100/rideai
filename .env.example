# ============================================================
#  RideAI — environment variables
#  Copy to ".env" and fill in real values. Never commit ".env".
# ============================================================

# --- AI (Claude) ---
ANTHROPIC_API_KEY=

# --- Google Maps (Places, Geocoding, Distance Matrix) ---
GOOGLE_MAPS_API_KEY=

# --- Supabase (Auth + Postgres) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Postgres / Supabase pooled connection string) ---
# Local docker default: postgresql://rideai:rideai@localhost:5432/rideai?schema=public
DATABASE_URL=

# --- Redis (cache + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Scraper test accounts (rotated 1..3 per platform) ---
RAPIDO_TEST_ACCOUNT_1_PHONE=
RAPIDO_TEST_ACCOUNT_1_OTP=
RAPIDO_TEST_ACCOUNT_2_PHONE=
RAPIDO_TEST_ACCOUNT_2_OTP=
RAPIDO_TEST_ACCOUNT_3_PHONE=
RAPIDO_TEST_ACCOUNT_3_OTP=

OLA_TEST_ACCOUNT_1_PHONE=
OLA_TEST_ACCOUNT_1_OTP=
OLA_TEST_ACCOUNT_2_PHONE=
OLA_TEST_ACCOUNT_2_OTP=
OLA_TEST_ACCOUNT_3_PHONE=
OLA_TEST_ACCOUNT_3_OTP=

UBER_TEST_ACCOUNT_1_PHONE=
UBER_TEST_ACCOUNT_1_OTP=
UBER_TEST_ACCOUNT_2_PHONE=
UBER_TEST_ACCOUNT_2_OTP=
UBER_TEST_ACCOUNT_3_PHONE=
UBER_TEST_ACCOUNT_3_OTP=

# --- Proxies (Bright Data residential) ---
BRIGHT_DATA_USERNAME=
BRIGHT_DATA_PASSWORD=
BRIGHT_DATA_HOST=brd.superproxy.io
BRIGHT_DATA_PORT=22225

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Backend server ---
PORT=3000
NODE_ENV=development
# Comma-separated origin allowlist for production CORS (required in prod).
# Dev: leave blank to accept any origin.
# Prod example: "https://rideai.vercel.app,https://rideai.in"
ALLOWED_ORIGINS=

# --- Error tracking (Sentry) ---
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# --- Mobile app (Expo public vars must be prefixed EXPO_PUBLIC_) ---
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
