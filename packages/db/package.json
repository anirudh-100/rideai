{
  "name": "@rideai/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
